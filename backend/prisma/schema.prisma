generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  USER
}

enum Status {
  ACTIVE
  BANNED
}

enum WorkStatus {
  DRAFT
  PUBLISHED
}

enum MessageStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LayoutMode {
  SINGLE
  DUAL
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum ReportType {
  INFRINGEMENT
  INAPPROPRIATE_CONTENT
  SPAM_AD
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum PointActionType {
  DAILY_LOGIN
  MESSAGE_APPROVED
  WORK_FAVORITED
  WORK_PUBLISHED
  ADMIN_ADJUST
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  passwordHash        String
  roleType            RoleType             @default(USER)
  permissions         String?              // Allowed string like "STYLE,WORK,USER,MESSAGE,SETTING"
  status              Status               @default(ACTIVE)
  points              Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  interactions        Interaction[]
  messages            Message[]
  operationLogs       OperationLog[]
  conversationsAsOne  Conversation[]       @relation("ConversationOne")
  conversationsAsTwo  Conversation[]       @relation("ConversationTwo")
  sentPrivateMessages PrivateMessage[]     @relation("MessageSender")
  receivedPrivateMessages PrivateMessage[] @relation("MessageReceiver")
  reports             Report[]             @relation("Reporter")
  handledReports      Report[]             @relation("Handler")
  pointLogs           PointLog[]
}

model Work {
  id           Int           @id @default(autoincrement())
  title        String
  description  String        @db.Text
  tags         String        // JSON array fallback
  category     String
  mediaUrl     String
  status       WorkStatus    @default(PUBLISHED)
  viewCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]
  reports      Report[]
}

model Interaction {
  id               Int      @id @default(autoincrement())
  user             User     @relation(fields: [userId], references: [id])
  userId           Int
  work             Work     @relation(fields: [workId], references: [id])
  workId           Int
  interactionType  String   // LIKE | FAVORITE
  createdAt        DateTime @default(now())
  
  @@unique([userId, workId, interactionType])
}

model StyleConfig {
  id              Int        @id @default(autoincrement())
  name            String
  primaryColor    String
  fontFamily      String
  layoutMode      LayoutMode @default(SINGLE)
  backgroundImage String?
  isActive        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Message {
  id        Int           @id @default(autoincrement())
  user      User          @relation(fields: [userId], references: [id])
  userId    Int
  content   String        @db.Text
  status    MessageStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SystemSetting {
  id                Int      @id @default(autoincrement())
  siteTitle         String   @default("My Website")
  logoUrl           String?
  contactInfo       String?
  icpInfo           String?
  enableMessageReview Boolean @default(true)
  enableWorkReview  Boolean  @default(false)
  enableRegistration Boolean @default(true)
  updatedAt         DateTime @updatedAt
}

model OperationLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  action    String
  detail    String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())
}

model Conversation {
  id              Int              @id @default(autoincrement())
  participantOne  User             @relation("ConversationOne", fields: [participantOneId], references: [id])
  participantOneId Int
  participantTwo  User             @relation("ConversationTwo", fields: [participantTwoId], references: [id])
  participantTwoId Int
  messages        PrivateMessage[]
  lastMessageAt   DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([participantOneId, participantTwoId])
}

model PrivateMessage {
  id              Int          @id @default(autoincrement())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId  Int
  sender          User         @relation("MessageSender", fields: [senderId], references: [id])
  senderId        Int
  receiver        User         @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId      Int
  content         String       @db.Text
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
}

model Media {
  id          Int       @id @default(autoincrement())
  filename    String
  originalName String
  fileUrl     String
  fileSize    Int
  mimeType    String
  mediaType   MediaType
  width       Int?
  height      Int?
  uploadedBy  User?     @relation(fields: [uploadedById], references: [id])
  uploadedById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([mediaType])
  @@index([createdAt])
}

model Report {
  id          Int          @id @default(autoincrement())
  work        Work         @relation(fields: [workId], references: [id], onDelete: Cascade)
  workId      Int
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  reporterId  Int
  reportType  ReportType
  description String       @db.Text
  status      ReportStatus @default(PENDING)
  handler     User?        @relation("Handler", fields: [handlerId], references: [id])
  handlerId   Int?
  handledAt   DateTime?
  handleNote  String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([workId, reporterId, reportType])
  @@index([workId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

model PointLog {
  id           Int             @id @default(autoincrement())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  actionType   PointActionType
  points       Int
  balanceAfter Int
  description  String?
  relatedId    Int?
  dedupKey     String?
  createdAt    DateTime        @default(now())

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@unique([userId, actionType, dedupKey])
}

model PointRule {
  id          Int             @id @default(autoincrement())
  actionType  PointActionType @unique
  points      Int
  description String
  isActive    Boolean         @default(true)
  dailyLimit  Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model LevelConfig {
  id        Int      @id @default(autoincrement())
  level     Int      @unique
  name      String
  minPoints Int
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
